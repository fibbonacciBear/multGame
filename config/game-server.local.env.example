# Local-only overrides for game tuning.
# Copy this file to config/game-server.local.env and edit only the keys you want to override.
# Values not set here fall back to config/game-server.env.
#
# Example overrides:
# GRAVITY_ACCEL=2000
# DRAG=0.96
# TERMINAL_SPEED=800
# SNAPSHOT_RATE=30
# CRASH_KNOCKBACK_IMPULSE=220
# PASSIVE_HEAL_PER_SECOND=2.0
# DISCONNECT_GRACE_PERIOD=10s
