{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Players (per pod)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "active_players_per_pod",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Lobby Player Count (humans + bots)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "game_lobby_player_count",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Pod Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(up{job=\"game-server\"} == 1)",
          "legendFormat": "game-server"
        },
        {
          "expr": "count(up{job=\"api-server\"} == 1)",
          "legendFormat": "api-server"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Game Tick Rate (Hz)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(game_tick_duration_seconds_count[1m])",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "hertz",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 58 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Tick Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(game_tick_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{ pod }}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(game_tick_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "WebSocket Messages Received (/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(game_ws_messages_received_total[1m])",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "WebSocket Connections (open / close rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(game_ws_connections_opened_total[5m])",
          "legendFormat": "opened {{ pod }}"
        },
        {
          "expr": "rate(game_ws_connections_closed_total[5m])",
          "legendFormat": "closed {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Kills (/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(game_player_kills_total[5m]) * 60",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Matches Completed (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(game_matches_completed_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Snapshot Broadcast Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(game_snapshot_broadcast_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "API Request Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, path) (rate(api_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ path }}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, path) (rate(api_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ path }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "API Request Rate (/s by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (path, status) (rate(api_http_requests_total[5m]))",
          "legendFormat": "{{ path }} {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Matchmaking Joins (/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(api_matchmaking_joins_total[5m]) * 60",
          "legendFormat": "joins/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Leaderboard Read/Write Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(api_leaderboard_reads_total[5m])",
          "legendFormat": "reads/s"
        },
        {
          "expr": "rate(api_leaderboard_writes_total[5m])",
          "legendFormat": "writes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Redis Errors (/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(api_redis_errors_total[5m]) * 60",
          "legendFormat": "errors/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["multgame", "game", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MultGame Overview",
  "uid": "multgame-overview",
  "version": 1
}
